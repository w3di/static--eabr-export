{
  "name": "polosatik",
  "version": "1.0.0",
  "description": "Starter project for developing a static site",
  "main": "index.js",
  "scripts": {
    "start": "webpack serve --env port=3000 --hot",
    "dev": "webpack serve --env port=3000 --hot",
    "build:prod": "webpack --env mode=production",
    "build:dev": "webpack --env mode=development",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss}\" \"config/**/*.ts\" webpack.config.ts",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss}\" \"config/**/*.ts\" webpack.config.ts",
    "lint:ts": "eslint \"**/*.{ts,tsx}\"",
    "lint:ts:fix": "eslint \"**/*.{ts,tsx}\" --fix",
    "lint:scss": "stylelint \"**/*.scss\"",
    "lint:scss:fix": "stylelint \"**/*.scss\" --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KennyNobody/polosatik.git"
  },
  "keywords": [
    "webpack",
    "typescript",
    "scss"
  ],
  "author": "Egor Badulin",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/KennyNobody/polosatik/issues"
  },
  "homepage": "https://github.com/KennyNobody/polosatik#readme",
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^18.14.1",
    "@types/webpack": "^5.28.0",
    "@types/webpack-dev-server": "^4.7.2",
    "@types/webpack-watch-files-plugin": "^1.1.3",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "autoprefixer": "^10.4.17",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.7.3",
    "eslint": "^8.56.0",
    "html-webpack-plugin": "^5.5.0",
    "mini-css-extract-plugin": "^2.7.7",
    "postcss": "^8.4.33",
    "postcss-loader": "^8.0.0",
    "prettier": "^3.8.3",
    "sass": "^1.58.3",
    "sass-loader": "^13.2.0",
    "style-loader": "^3.3.1",
    "stylelint": "^16.2.0",
    "stylelint-config-standard-scss": "^16.0.0",
    "svg-sprite-loader": "^6.0.11",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.11.1",
    "webpack-watch-files-plugin": "^1.2.1"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "dependencies": {
    "@fancyapps/ui": "^5.0.36",
    "@popperjs/core": "^2.11.8",
    "air-datepicker": "^3.6.0",
    "animejs": "^4.4.1",
    "i18next": "^26.1.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "libphonenumber-js": "^1.13.0",
    "slim-select": "^3.4.3",
    "swiper": "^11.1.3",
    "the-new-css-reset": "^1.11.2"
  }
}
